// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
}

model Candidate {
  id        Int     @id @default(autoincrement())
  firstName String
  lastName  String
  email     String  @unique
  phone     String
  dateOfBirth DateTime
  resumeLink String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  description String
  createdAt   DateTime @default(now())
}